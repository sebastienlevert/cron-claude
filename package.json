{
  "name": "@sebastienlevert/cron-agents",
  "version": "0.1.5",
  "description": "Scheduled Claude task execution - MCP server for automating recurring tasks via cron schedules",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "cron-agents": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".claude-plugin",
    ".mcp.json",
    "CLAUDE.md",
    "commands",
    "hooks",
    "skills",
    "tasks",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js mcp",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm run validate && node scripts/swap-mcp-config.js publish",
    "postpublish": "node scripts/swap-mcp-config.js dev",
    "validate": "node scripts/validate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "preversion": "npm run build",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-plugin",
    "automation",
    "cron",
    "scheduler",
    "mcp",
    "model-context-protocol",
    "windows",
    "task-scheduler"
  ],
  "author": "Patrick Rodgers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastienlevert/cron-agents.git"
  },
  "homepage": "https://github.com/sebastienlevert/cron-agents#readme",
  "bugs": {
    "url": "https://github.com/sebastienlevert/cron-agents/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4"
  }
}
